{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bin/phpcs:*)",
      "Bash(bin/phpcbf:*)",
      "Bash(bin/phpstan:*)",
      "Bash(bin/php-syntax-check:*)",
      "Bash(bin/composer:*)",
      "Bash(bin/npm:*)",
      "Bash(bin/playwright:*)",
      "Bash(php -l:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git --version)",
      "Skill(sq-git:commit)",
      "Skill(sq-git:open-pr)",
      "Skill(sq-git:sync-branch)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": [
      "Bash(./setup.sh:*)",
      "Bash(./teardown.sh:*)",
      "Bash(git push:*)"
    ]
  }
}
