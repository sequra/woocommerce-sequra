# !/bin/sh
# This script copies the source files from within the container to the host.
# Usefull for debugging and development.
BASEDIR="$(dirname $(realpath $0))/.."
# get id of the container
container_id=$(docker ps | grep woocommerce-sequra-web | head -n 1 | awk '{print $1}')

if [ -z "$container_id" ]; then
    echo "Container not found! Skipping copy."
else
    echo "Copying source files from container $container_id to host..."
    # wp-includes
    docker cp "$container_id":/var/www/html/wp-includes "${BASEDIR}"/docker
    # wp-admin
    docker cp "$container_id":/var/www/html/wp-admin "${BASEDIR}"/docker
    # plugins
    mkdir -p "${BASEDIR}"/docker/wp-content/plugins
    docker cp "$container_id":/var/www/html/wp-content/plugins/woocommerce "${BASEDIR}"/docker/wp-content/plugins || true
    docker cp "$container_id":/var/www/html/wp-content/plugins/learnpress "${BASEDIR}"/docker/wp-content/plugins || true
    # Wordpress Test libs
    mkdir -p "${BASEDIR}"/docker/wordpress-tests-lib
    docker cp "$container_id":/tmp/wordpress-tests-lib/data "${BASEDIR}"/docker/wordpress-tests-lib || true
    docker cp "$container_id":/tmp/wordpress-tests-lib/includes "${BASEDIR}"/docker/wordpress-tests-lib || true
    
    echo "Done!"
fi